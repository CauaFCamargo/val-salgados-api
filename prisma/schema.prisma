generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // O projeto é CommonJS; sem isso o gerador emite ESM (import.meta) e o build
  // com tsc + node quebra. Force CJS pra bater com o "type": "commonjs".
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Pedido {
  id       Int      @id @default(autoincrement())
  numero   Int      @unique @default(autoincrement())
  criadoEm DateTime @default(now())

  // Chave do link público de acompanhamento (/pedido/<token>).
  // `numero` é sequencial e serve pra loja se organizar, mas justamente por ser
  // previsível NÃO pode dar acesso: qualquer um contaria 1, 2, 3... e leria os
  // pedidos alheios (IDOR). O token é aleatório e inviável de adivinhar.
  // Gerado pelo banco (gen_random_uuid) pra as linhas antigas também receberem.
  token String @unique @default(dbgenerated("gen_random_uuid()::text"))

  clienteNome String
  telefone    String

  // Entrega x Retirada: no RETIRADA não há endereço, por isso os campos
  // de endereço são opcionais. Qual foi a escolha fica em `tipoEntrega`.
  tipoEntrega String  @default("ENTREGA") // "ENTREGA" | "RETIRADA"
  // `endereco` guarda só a rua/logradouro; número, bairro e cidade têm campos
  // próprios pra a entregadora não precisar interpretar um texto solto.
  endereco       String?
  // "numeroEndereco" e não "numero" porque `numero` já é o número do PEDIDO.
  // É texto, não inteiro: existe "123A", "s/n", "km 5".
  numeroEndereco String?
  bairro         String?
  cidade         String?
  cep            String? // guardado com máscara: "18103-000"
  complemento    String?

  subtotal    Float
  taxaEntrega Float @default(0)
  desconto    Float @default(0)
  total       Float

  // Pagamento: PIX ou dinheiro. `trocoPara` só faz sentido no dinheiro
  // (quanto o cliente vai pagar em espécie, pra calcular o troco).
  formaPagamento String  @default("PIX") // "PIX" | "DINHEIRO"
  trocoPara      Float?

  status String @default("RECEBIDO")

  // O agente de impressão da loja marca como true depois de imprimir o cupom.
  // Garante que cada pedido seja impresso uma única vez.
  impresso Boolean @default(false)

  itens ItemPedido[]
}

model ItemPedido {
  id Int @id @default(autoincrement())

  nome          String
  quantidade    Int
  precoUnitario Float

  pedido   Pedido @relation(fields: [pedidoId], references: [id])
  pedidoId Int
}
